# ═══════════════════════════════════════════════════════════
# GEKTOR APEX — Environment Variables Template
# Скопируйте в .env и заполните реальными значениями.
# ═══════════════════════════════════════════════════════════

# ── БАЗА ДАННЫХ (PostgreSQL / TimescaleDB) ──
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
ASYNC_DATABASE_URL=postgresql+asyncpg://tekton_admin:CHANGE_ME@localhost:5433/tekton_alpha

# ── ШИНА (Redis) ──
REDIS_PASSWORD=CHANGE_ME_DIFFERENT_FROM_POSTGRES

# ── BYBIT API (обязательно) ──
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── TELEGRAM (уведомления) ──
TG_BOT_TOKEN=
TG_CHAT_ID=

# ── ПРОКСИ (опционально) ──
# USE_PROXY_FOR_BYBIT=false
# TG_PROXY_URL=
