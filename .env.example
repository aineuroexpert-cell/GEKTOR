# GEKTOR APEX v3.6.0 — .env.example
#
# Copy this file to .env (local dev) or .env.production (Tokyo VPS).
# NEVER commit your real .env / .env.production to git.

# ---- TELEGRAM (REQUIRED) ----
# Obtain from @BotFather. If the token has ever appeared in a chat,
# revoke it via @BotFather and generate a new one.
BOT_TOKEN=0:replace_with_real_token_from_botfather
# Numeric Telegram chat ID where alerts are sent.
CHAT_ID=0

# ---- DATABASE ----
# Default: local SQLite. The codebase is SQLite-compatible (no PG-only
# SQL). For production on Tokyo VPS, replace with PostgreSQL DSN.
ASYNC_DATABASE_URL=sqlite+aiosqlite:///gektor.db

# ---- POSTGRES (only used if ASYNC_DATABASE_URL points to postgres) ----
POSTGRES_PASSWORD=your_secure_postgres_password_here

# ---- REDIS (used by ReliableIngestionBuffer) ----
# Optional: leave default if no Redis. Buffer will fall back to disk
# spillover automatically.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here

# ---- RADAR TUNING ----
# Dollar threshold for one bar in USD. Lower => more bars => more sensitive.
DOLLAR_THRESHOLD_BASE=100000
# Per-symbol alert cooldown in seconds (prevents spam during sustained anomaly).
RADAR_COOLDOWN_SEC=300
# Watchdog: alert if no tick received for this many seconds.
WATCHDOG_SILENCE_SEC=60
# Watchdog poll interval.
WATCHDOG_POLL_SEC=10

# ---- PROXY (optional) ----
# Set if your VPS region requires an outbound proxy for Bybit / Telegram.
PROXY_URL=
TG_PROXY_URL=
USE_PROXY_FOR_BYBIT=false
