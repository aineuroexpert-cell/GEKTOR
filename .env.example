# GEKTOR APEX v3.6.2 — .env.example
#
# Copy this file to .env (local dev) or /opt/gektor/.env on the Tokyo
# VPS. NEVER commit your real .env to git. NEVER paste any of these
# values into chat, docs, or PRs.

# ============================================================
# REQUIRED
# ============================================================

# --- Database ---
# Default: local SQLite (file in repo dir). The radar's code path is
# SQLite-compatible end-to-end (no PG-only SQL). For PostgreSQL, use
# e.g. ASYNC_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db
ASYNC_DATABASE_URL=sqlite+aiosqlite:///gektor.db

# ============================================================
# OPTIONAL — but you almost certainly want Telegram on prod
# ============================================================

# --- Telegram alert sink ---
# Obtain from @BotFather. If the token has EVER appeared in a chat,
# revoke it via @BotFather and generate a new one before deploy.
#
# The config accepts any of these env names (all map to the same field):
#   BOT_TOKEN, TELEGRAM_BOT_TOKEN, TG_BOT_TOKEN, GERALD_BOT_TOKEN
#   CHAT_ID,  TELEGRAM_CHAT_ID,    TG_CHAT_ID
BOT_TOKEN=
CHAT_ID=

# --- Bybit credentials ---
# OPTIONAL. The Advisory radar uses ONLY the public publicTrade WS
# endpoint and does NOT need a signed API key for its data path. Leave
# blank unless you have configured a future REST consumer that needs
# authentication. If set, BYBIT_API_KEY must be 18–24 alphanumeric chars
# and BYBIT_API_SECRET must be 36–50 alphanumeric chars.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ============================================================
# Optional infra
# ============================================================

# --- PostgreSQL (only when ASYNC_DATABASE_URL points at postgres) ---
POSTGRES_PASSWORD=

# --- Redis (only used by ReliableIngestionBuffer's optional spillover) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================
# Radar tuning (v3.6.2)
# ============================================================
# --- Sensitivity tier (the main knob for active vs swing trading) ---
#   conservative — z=2.5σ, window=50, cooldown=600s → 1-3 alerts/day
#   active       — z=2.0σ, window=50, cooldown=300s → 5-15 alerts/day [DEFAULT]
#   scanner      — z=1.7σ, window=30, cooldown=120s → 30-50 alerts/day
SENSITIVITY=active

# --- Dollar bar size ---
# Base fallback for unknown symbols (used when adaptive is off OR before
# first turnover refresh succeeds).
DOLLAR_THRESHOLD_BASE=1000000

# --- Adaptive per-symbol $-threshold (v3.6.2) ---
# Sizes the bar from 24h turnover so BTC and tail-cap altcoins both
# produce ~ADAPTIVE_TARGET_BARS_PER_DAY bars/day. Without this, a fixed
# $1M bar on a $10M/day altcoin means the VPIN warmup takes ~5 days.
ADAPTIVE_THRESHOLD_ENABLE=true
ADAPTIVE_TARGET_BARS_PER_DAY=200
ADAPTIVE_MIN_USD=20000
ADAPTIVE_MAX_USD=5000000
ADAPTIVE_REFRESH_SEC=3600

# --- Liquidity detectors (instant fire, no warmup) ---
LIQUIDITY_DETECTORS_ENABLE=true
# Sweep: ≥N same-side aggressor trades summing to ≥$NOTIONAL within WINDOW sec.
SWEEP_MIN_TRADES=5
SWEEP_WINDOW_SEC=30
SWEEP_MIN_NOTIONAL_USD=100000
# Large print: single trade ≥ PCT × 24h turnover (0.005 = 0.5%).
LARGE_PRINT_PCT_THRESHOLD=0.005
LARGE_PRINT_MIN_NOTIONAL_USD=25000
# OFI Pulse: 1-min OFI > K × rolling 1-hour median.
OFI_PULSE_K=3.0
OFI_PULSE_BUCKET_SEC=60
OFI_PULSE_HISTORY_BUCKETS=60
OFI_PULSE_MIN_NOTIONAL_USD=50000

# --- Common ---
# Per-symbol alert cooldown override (defaults derived from SENSITIVITY tier).
# Uncomment to override.
# RADAR_COOLDOWN_SEC=300

# Watchdog: alert if no tick received for this many seconds.
WATCHDOG_SILENCE_SEC=60
# Watchdog poll interval.
WATCHDOG_POLL_SEC=10

# ============================================================
# Proxy (optional — only set if your VPS region needs one)
# ============================================================
# SOCKS5 example: socks5://user:pass@host:port
# HTTP   example: http://user:pass@host:port
PROXY_URL=
TG_PROXY_URL=
USE_PROXY_FOR_BYBIT=false
