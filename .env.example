# GEKTOR APEX v3.6.1 — .env.example
#
# Copy this file to .env (local dev) or /opt/gektor/.env on the Tokyo
# VPS. NEVER commit your real .env to git. NEVER paste any of these
# values into chat, docs, or PRs.

# ============================================================
# REQUIRED
# ============================================================

# --- Database ---
# Default: local SQLite (file in repo dir). The radar's code path is
# SQLite-compatible end-to-end (no PG-only SQL). For PostgreSQL, use
# e.g. ASYNC_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db
ASYNC_DATABASE_URL=sqlite+aiosqlite:///gektor.db

# ============================================================
# OPTIONAL — but you almost certainly want Telegram on prod
# ============================================================

# --- Telegram alert sink ---
# Obtain from @BotFather. If the token has EVER appeared in a chat,
# revoke it via @BotFather and generate a new one before deploy.
#
# The config accepts any of these env names (all map to the same field):
#   BOT_TOKEN, TELEGRAM_BOT_TOKEN, TG_BOT_TOKEN, GERALD_BOT_TOKEN
#   CHAT_ID,  TELEGRAM_CHAT_ID,    TG_CHAT_ID
BOT_TOKEN=
CHAT_ID=

# --- Bybit credentials ---
# OPTIONAL. The Advisory radar uses ONLY the public publicTrade WS
# endpoint and does NOT need a signed API key for its data path. Leave
# blank unless you have configured a future REST consumer that needs
# authentication. If set, BYBIT_API_KEY must be 18–24 alphanumeric chars
# and BYBIT_API_SECRET must be 36–50 alphanumeric chars.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ============================================================
# Optional infra
# ============================================================

# --- PostgreSQL (only when ASYNC_DATABASE_URL points at postgres) ---
POSTGRES_PASSWORD=

# --- Redis (only used by ReliableIngestionBuffer's optional spillover) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================
# Radar tuning
# ============================================================
# Dollar threshold for one bar in USD. Lower => more bars => more sensitive.
DOLLAR_THRESHOLD_BASE=1000000
# Per-symbol alert cooldown in seconds (prevents spam during sustained anomaly).
RADAR_COOLDOWN_SEC=300
# Watchdog: alert if no tick received for this many seconds.
WATCHDOG_SILENCE_SEC=60
# Watchdog poll interval.
WATCHDOG_POLL_SEC=10

# ============================================================
# Proxy (optional — only set if your VPS region needs one)
# ============================================================
# SOCKS5 example: socks5://user:pass@host:port
# HTTP   example: http://user:pass@host:port
PROXY_URL=
TG_PROXY_URL=
USE_PROXY_FOR_BYBIT=false
